# Multi-environment setup (Vault OS + Cosmo OS)
#
# This repo deploys to three databases with the same Prisma schema:
#   1. Vault OS          → .env.vault
#   2. Cosmo OS (dev)    → .env.cosmo-dev
#   3. Cosmo OS (prod)   → .env.cosmo-prod
#
# Each file has its own Neon DATABASE_URL/DIRECT_URL and Auth0 credentials.
#
# Setup (once per machine):
#   cp .env.vault.example .env.vault
#   cp .env.cosmo-dev.example .env.cosmo-dev
#   cp .env.cosmo-prod.example .env.cosmo-prod   # team lead only
#   Fill in values from your team secret store.
#
# Switch active env (copies target → .env for Next.js):
#   npm run env:use              # interactive
#   npm run env:use vault        # working on Vault OS
#   npm run env:use cosmo-dev    # working on Cosmo dev
#
# Or run dev without switching .env:
#   npm run dev:vault
#   npm run dev:cosmo-dev
#
# Migrations (one prisma/migrations folder — apply to each DB):
#   npm run db:migrate           # create migration (cosmo-dev only)
#   npm run db:deploy:cosmo-dev  # apply pending migrations
#   npm run db:deploy:vault
#   npm run db:deploy:cosmo-prod
#   npm run db:deploy:all        # all three (prod asks for confirmation)
#
# Check migration state per DB:
#   npm run db:status:cosmo-dev
#   npm run db:status:vault
#   npm run db:status:cosmo-prod
#
# Rules:
#   - Never use db:push on shared or production databases
#   - After merging a new migration, run db:deploy:all (or each target in CI)
#   - db:migrate only on cosmo-dev when authoring schema changes

APP_BASE_URL="https://localhost:3000"
NEXT_PUBLIC_APP_NAME="Cosmo OS"
NEXT_PUBLIC_APP_INITIALS="CO"

DATABASE_URL="postgresql://neondb_owner:<password>@your-project-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:<password>@your-project.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Auth0 (web login via @auth0/nextjs-auth0)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_DATABASE_CONNECTION=Username-Password-Authentication

MAILEROO_API_KEY=
MAILEROO_FROM_EMAIL=noreply@yourdomain.com
SHOPIFY_WEBHOOK_SECRET=
CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# DB Observability (optional)
DB_REQUEST_SLOW_MS=400
PRISMA_LOG_SLOW_QUERIES=false
PRISMA_SLOW_QUERY_MS=250
PRISMA_SLOW_QUERY_SAMPLE_RATE=1

# App performance logging (optional)
ENABLE_PERF_LOGS=false

# ERPNext integration (optional)
# Used by lib/erpnext-sync.ts, webhooks, and the Cursor MCP server (scripts/mcp-erpnext.mjs)
# Token-based auth: Settings > API Access > Generate Keys
ERPNEXT_BASE_URL=https://erpnext-supplement-vault-2-poc.m.frappe.cloud
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_BANK_TRANSFER_MOP=Wire Transfer
ERPNEXT_CASH_MOP=Cash
ERPNEXT_COD_MOP=Cash On Delivery
ERPNEXT_CARD_DELIVERY_MOP=Credit Card
ERPNEXT_TAXES_AND_CHARGES=
ERPNEXT_SHIPPING_RULE=
ERPNEXT_INCOMING_WEBHOOK_SECRET=
