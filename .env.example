DATABASE_URL="postgresql://neondb_owner:<password>@your-project-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:<password>@your-project.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Auth0 Management API - Create M2M app with create:users and delete:users permissions
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_DATABASE_CONNECTION=Username-Password-Authentication

# Maileroo - For sending invite emails
MAILEROO_API_KEY=
MAILEROO_FROM_EMAIL=noreply@yourdomain.com

# Shopify - Webhook secret for verifying product webhooks (products/create, products/update)
# Register webhook URL: https://<your-domain>/api/webhooks/shopify/products?location_id=<shopifyLocationId>
SHOPIFY_WEBHOOK_SECRET=

# Cloudinary - Get from Product Environment Credentials (cloudinary.com)
# CLOUDINARY_URL: For server-side uploads. Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME: For CldImage delivery (e.g. djfjrbluj)
CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Neon - Get from Neon Console > Connect
# DATABASE_URL: Pooled connection (has -pooler in hostname) for app runtime
# DIRECT_URL: Direct connection (no -pooler) for Prisma CLI (migrations, db push)
DATABASE_URL="postgresql://[user]:[password]@[endpoint]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require"
DIRECT_URL="postgresql://[user]:[password]@[endpoint].[region].aws.neon.tech/[dbname]?sslmode=require"

# DB Observability (optional)
# Request-level slow log threshold in ms (used by page-data helpers)
DB_REQUEST_SLOW_MS=400
# Enable Prisma query-event slow logs outside dev
PRISMA_LOG_SLOW_QUERIES=false
# Prisma slow query threshold in ms
PRISMA_SLOW_QUERY_MS=250
# Sampling rate for slow query logs (0..1)
PRISMA_SLOW_QUERY_SAMPLE_RATE=1

# App performance logging (optional)
# Logs auth/request timing for selected routes when set to true
ENABLE_PERF_LOGS=false
