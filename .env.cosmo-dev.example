# Cosmo OS (dev) — default for creating migrations & team local dev
# Copy to .env.cosmo-dev and fill in real values (gitignored)

APP_BASE_URL="https://localhost:3000"
NEXT_PUBLIC_APP_NAME="Cosmo OS"
NEXT_PUBLIC_APP_INITIALS="CO"

# Neon — Cosmo OS shared dev database
DATABASE_URL="postgresql://neondb_owner:<password>@your-cosmo-dev-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:<password>@your-cosmo-dev.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Auth0 — Cosmo OS dev tenant
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_DATABASE_CONNECTION=Username-Password-Authentication

# Maileroo
MAILEROO_API_KEY=
MAILEROO_FROM_EMAIL=noreply@yourdomain.com

# Shopify (Cosmetics store webhooks)
SHOPIFY_WEBHOOK_SECRET=
# Shopify Admin API — required for cancel_order action (Private App or Custom App access token)
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Cloudinary (Cosmo media)
CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ERPNext (Cosmo instance — optional)
ERPNEXT_BASE_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_BANK_TRANSFER_MOP=Wire Transfer
ERPNEXT_CASH_MOP=Cash
ERPNEXT_COD_MOP=Cash On Delivery
ERPNEXT_CARD_DELIVERY_MOP=Credit Card
ERPNEXT_TAXES_AND_CHARGES=
ERPNEXT_SHIPPING_RULE=
ERPNEXT_INCOMING_WEBHOOK_SECRET=

# Optional
DB_REQUEST_SLOW_MS=400
PRISMA_LOG_SLOW_QUERIES=false
PRISMA_SLOW_QUERY_MS=250
PRISMA_SLOW_QUERY_SAMPLE_RATE=1
ENABLE_PERF_LOGS=false
