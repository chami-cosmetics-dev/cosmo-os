# Local development (single backend — both tenants use this URL when vault URL is unset)
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000

# Multi-tenant production URLs (one APK, merged deliveries)
# EXPO_PUBLIC_COSMETICS_API_URL=https://os.cosmetics.lk
# EXPO_PUBLIC_VAULT_API_URL=https://vault-os-sandy.vercel.app

# Optional crash reporting (leave empty locally)
# EXPO_PUBLIC_SENTRY_DSN=

# --- Staging build (EAS profile: preview) ---
# EXPO_PUBLIC_APP_ENV=staging
# EXPO_PUBLIC_COSMETICS_API_URL=https://your-staging-cosmetics-domain.com
# EXPO_PUBLIC_VAULT_API_URL=https://your-staging-vault-domain.com
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --- Production build (EAS profile: production) ---
# EXPO_PUBLIC_APP_ENV=production
# EXPO_PUBLIC_COSMETICS_API_URL=https://os.cosmetics.lk
# EXPO_PUBLIC_VAULT_API_URL=https://vault-os-sandy.vercel.app
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# EAS source map upload (set in EAS secrets, not in the app bundle)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
