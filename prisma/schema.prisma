model RiderDeliveryTask {
  id                        String                  @id @default(cuid())
  orderId                   String                  @unique
  riderId                   String
  status                    RiderDeliveryTaskStatus @default(assigned)
  deliveryKind              RiderDeliveryKind       @default(normal)
  exchangeId                String?
  oldOrderLabel             String?
  replacementOrderLabel     String?
  requiresOldItemCollection Boolean                 @default(false)
