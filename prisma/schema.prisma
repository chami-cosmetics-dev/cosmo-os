generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                       String                    @id @default(cuid())
  name                     String
  employeeSize             String?
  address                  String?
  createdById              String                    @unique
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  logoUrl                  String?
  faviconUrl               String?
  categories               Category[]
  createdBy                User                      @relation("CompanyCreator", fields: [createdById], references: [id], onDelete: Cascade)
  locations                CompanyLocation[]
  courierServices          CourierService[]
  customers                Customer[]
  departments              Department[]
  designations             Designation[]
  suppliers                Supplier[]
  emailTemplates           EmailTemplate[]
  employeeProfiles         EmployeeProfile[]
  failedOrderWebhooks      FailedOrderWebhook[]
  auditLogs                AuditLog[]
  invites                  Invite[]
  orders                   Order[]
  packageHoldReasons       PackageHoldReason[]
  productItems             ProductItem[]
  cosmoAcademyExplanations CosmoAcademyExplanation[]
  cosmoAcademyProgress     CosmoAcademyProgress[]
  sampleFreeIssueItems     SampleFreeIssueItem[]
  shopifyWebhookSecrets    ShopifyWebhookSecret[]
  stickerBatches           StickerBatch[]
  stickerBatchItems        StickerBatchItem[]
  merchantOrderReviews     MerchantOrderReview[]
  orderExchanges           OrderExchange[]
  orderReturns             OrderReturn[]
  orderWaybillUploads      WaybillUpload[]
  orderWaybills            OrderWaybill[]
  approvalRequests         ApprovalRequest[]
  notifications            Notification[]
  smsLogs                  SmsLog[]
  smsNotificationConfigs   SmsNotificationConfig[]
  smsPortalConfig          SmsPortalConfig?
  users                    User[]                    @relation("CompanyMembers")
  vendors                  Vendor[]
  contacts                 ContactMaster[]
  complaints               Complaint[]
  shippingChargeOptions    ShippingChargeOption[]
  kokoCompanies            KokoCompany[]
  dashboardBrandConfigs    DashboardBrandConfig[]
  contactAllocationOptions ContactAllocationOption[]
  productItemAssets        ProductItemAsset[]
  // Call center performance tracking: records each time a merchant clicks Update
  // in the allocation panel — drives the dashboard performance analysis chart
  contactAllocationUpdates ContactAllocationUpdate[]
  erpnextInstances         ErpnextInstance[]
  pickListGroups           PickListGroup[]
}

model ErpnextInstance {
  id                    String            @id @default(cuid())
  companyId             String
  label                 String
  baseUrl               String
  apiKey                String
  apiSecret             String
  incomingWebhookSecret String?
  cashMop               String?
  codMop                String?
  cardDeliveryMop       String?
  bankTransferMop       String?
  kokoMop               String?
  webxpayMop            String?
  taxesAndCharges       String?
  shippingRule          String?
  shippingItem          String?
  shippingChargeAccount String?
  /// When set, only Shopify orders created at or after this time are synced to ERPNext SI.
  shopifySyncEnabledAt  DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locations             CompanyLocation[]

  @@index([companyId])
}

model FailedOrderWebhook {
  id                  String          @id @default(cuid())
  companyId           String
  companyLocationId   String
  shopifyOrderId      String
  shopifyTopic        String?
  errorMessage        String
  errorStack          String?
  rawPayload          Json
  autoRetryCount      Int             @default(0)
  lastAutoRetryAt     DateTime?
  nextAutoRetryAt     DateTime?
  retryLeaseExpiresAt DateTime?
  resolvedAt          DateTime?
  createdAt           DateTime        @default(now())
  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyLocation     CompanyLocation @relation(fields: [companyLocationId], references: [id], onDelete: Cascade)

  @@index([companyId, resolvedAt, createdAt(sort: Desc)])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, resolvedAt, nextAutoRetryAt])
}

model ShopifyWebhookSecret {
  id        String   @id @default(cuid())
  companyId String
  name      String?
  secret    String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model DashboardBrandConfig {
  id         String   @id @default(cuid())
  companyId  String
  /// Brand name searched (case-insensitive) in product titles
  name       String
  isSelected Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId, sortOrder])
}

model Vendor {
  id           String        @id @default(cuid())
  companyId    String
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  productItems ProductItem[]
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
}

model Category {
  id           String        @id @default(cuid())
  companyId    String
  name         String
  fullName     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productItems ProductItem[]

  @@unique([companyId, name])
}

model ProductItem {
  id                              String                    @id @default(cuid())
  companyId                       String
  companyLocationId               String
  shopifyLocationId               String
  shopifyProductId                String
  shopifyVariantId                String
  productTitle                    String
  variantTitle                    String?
  sku                             String?
  price                           Decimal                   @db.Decimal(12, 2)
  compareAtPrice                  Decimal?                  @db.Decimal(12, 2)
  vendorId                        String?
  categoryId                      String?
  status                          String?
  productType                     String?
  handle                          String?
  imageUrl                        String?
  tags                            String?
  barcode                         String?
  itemStatusCategory              String                    @default("UNCATEGORIZED")
  itemStatusLabel                 String?
  inventoryQuantity               Int                       @default(0)
  createdAt                       DateTime                  @default(now())
  updatedAt                       DateTime                  @updatedAt
  orderLineItems                  OrderLineItem[]
  cosmoAcademyPrimaryExplanations CosmoAcademyExplanation[] @relation("CosmoAcademyPrimaryProductItem")
  category                        Category?                 @relation(fields: [categoryId], references: [id])
  company                         Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyLocation                 CompanyLocation           @relation(fields: [companyLocationId], references: [id], onDelete: Cascade)
  vendor                          Vendor?                   @relation(fields: [vendorId], references: [id])
  sampleFreeIssueItems            SampleFreeIssueItem[]

  @@unique([companyLocationId, shopifyVariantId])
  @@index([companyId, productTitle, variantTitle])
  @@index([companyId, companyLocationId])
  @@index([companyId, vendorId])
  @@index([companyId, categoryId])
  @@index([companyId, itemStatusCategory])
}

model Invite {
  id              String           @id @default(cuid())
  email           String
  token           String           @unique
  expiresAt       DateTime
  usedAt          DateTime?
  invitedById     String?
  roleId          String
  isSuperAdmin    Boolean          @default(false)
  createdAt       DateTime         @default(now())
  companyId       String?
  appointmentDate DateTime?
  departmentId    String?
  designationId   String?
  employeeNumber  String?
  epfNumber       String?
  locationId      String?
  company         Company?         @relation(fields: [companyId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  designation     Designation?     @relation(fields: [designationId], references: [id])
  invitedBy       User?            @relation("InvitedBy", fields: [invitedById], references: [id])
  location        CompanyLocation? @relation(fields: [locationId], references: [id])
  role            Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

model User {
  id                              String                    @id @default(cuid())
  auth0Id                         String                    @unique
  email                           String?                   @unique
  name                            String?
  picture                         String?
  createdAt                       DateTime                  @default(now())
  updatedAt                       DateTime                  @updatedAt
  companyId                       String?
  dateOfBirth                     DateTime?
  gender                          String?
  knownName                       String?
  mobile                          String?
  nicNo                           String?
  couponCodes                     String[]                  @default([])
  shopifyUserIds                  String[]                  @default([])
  erpnextUsername                 String?                   @unique
  profilePhotoUrl                 String?
  createdCompany                  Company?                  @relation("CompanyCreator")
  defaultMerchantLocations        CompanyLocation[]         @relation("LocationDefaultMerchant")
  employeeProfile                 EmployeeProfile?
  invitesSent                     Invite[]                  @relation("InvitedBy")
  assignedOrders                  Order[]                   @relation("OrderAssignedMerchant")
  ordersDeliveryCompleteBy        Order[]                   @relation("OrderDeliveryCompleteBy")
  ordersDispatchedBy              Order[]                   @relation("OrderDispatchedBy")
  dispatchedOrders                Order[]                   @relation("OrderDispatchedByRider")
  exchangeActions                 OrderExchange[]           @relation("OrderExchangeActionBy")
  exchangeCreated                 OrderExchange[]           @relation("OrderExchangeCreatedBy")
  exchangeMerchantAssignments     OrderExchange[]           @relation("OrderExchangeMerchantUser")
  ordersInvoiceCompleteBy         Order[]                   @relation("OrderInvoiceCompleteBy")
  ordersLastPrintedBy             Order[]                   @relation("OrderLastPrintedBy")
  ordersPackageReadyBy            Order[]                   @relation("OrderPackageReadyBy")
  ordersSampleFreeIssueCompleteBy Order[]                   @relation("OrderSampleFreeIssueCompleteBy")
  orderRemarksAdded               OrderRemark[]
  orderSampleFreeIssuesAdded      OrderSampleFreeIssue[]
  smsLogs                         SmsLog[]
  company                         Company?                  @relation("CompanyMembers", fields: [companyId], references: [id])
  deliveryPayments                DeliveryPayment[]
  mobileSessions                  RiderMobileSession[]
  merchantOrderReviews            MerchantOrderReview[]     @relation("MerchantOrderReviewUser")
  merchantOrderReturns            OrderReturn[]             @relation("OrderReturnMerchantUser")
  orderReturnsActioned            OrderReturn[]             @relation("OrderReturnActionBy")
  orderReturnsMarked              OrderReturn[]             @relation("OrderReturnReturnedBy")
  orderReturnsRidden              OrderReturn[]             @relation("OrderReturnRider")
  complaintsCreated               Complaint[]               @relation("ComplaintCreatedBy")
  complaintsResolved              Complaint[]               @relation("ComplaintResolvedBy")
  waybillUploads                  WaybillUpload[]
  approvalRequestsRequested       ApprovalRequest[]         @relation("ApprovalRequestRequestedBy")
  approvalRequestsReviewed        ApprovalRequest[]         @relation("ApprovalRequestReviewedBy")
  notifications                   Notification[]
  receivedCashHandovers           RiderCashHandover[]       @relation("RiderCashHandoverReceivedBy")
  riderCashHandovers              RiderCashHandover[]       @relation("RiderCashHandovers")
  riderDeliveryTasks              RiderDeliveryTask[]
  userRoles                       UserRole[]
  auditLogs                       AuditLog[]                @relation("AuditLogActor")
  cosmoAcademyExplanationsCreated CosmoAcademyExplanation[] @relation("CosmoAcademyExplanationCreatedBy")
  cosmoAcademyProgress            CosmoAcademyProgress[]
  productItemAssets               ProductItemAsset[]
  // Call center performance tracking: records updates made by this merchant user
  contactAllocationUpdates        ContactAllocationUpdate[]
  pickListGroupsPrinted           PickListGroup[]         @relation("PickListGroupPrintedBy")
}

model CosmoAcademyExplanation {
  id                   String                 @id @default(cuid())
  companyId            String
  primaryProductItemId String
  createdById          String?
  productKey           String
  shopifyProductId     String?
  productTitle         String
  title                String?
  notes                String?
  status               String                 @default("published")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  company              Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  primaryProductItem   ProductItem            @relation("CosmoAcademyPrimaryProductItem", fields: [primaryProductItemId], references: [id], onDelete: Cascade)
  createdBy            User?                  @relation("CosmoAcademyExplanationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  media                CosmoAcademyMedia[]
  progress             CosmoAcademyProgress[]

  @@index([companyId, productKey])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([primaryProductItemId])
}

model CosmoAcademyProgress {
  id            String                  @id @default(cuid())
  companyId     String
  explanationId String
  userId        String
  status        String                  @default("not_started")
  lastOpenedAt  DateTime?
  completedAt   DateTime?
  rating        Int?
  reviewNotes   String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  company       Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  explanation   CosmoAcademyExplanation @relation(fields: [explanationId], references: [id], onDelete: Cascade)
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([explanationId, userId])
  @@index([companyId, userId, status])
  @@index([companyId, updatedAt(sort: Desc)])
}

model CosmoAcademyMedia {
  id            String                  @id @default(cuid())
  explanationId String
  mediaType     CosmoAcademyMediaType
  url           String
  provider      String?
  publicId      String?
  fileName      String?
  mimeType      String?
  sizeBytes     Int?
  createdAt     DateTime                @default(now())
  explanation   CosmoAcademyExplanation @relation(fields: [explanationId], references: [id], onDelete: Cascade)

  @@index([explanationId])
}

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String?
  actorUserId String?
  module      String
  action      String
  entityType  String?
  entityId    String?
  summary     String
  beforeData  Json?
  afterData   Json?
  metadata    Json?
  createdAt   DateTime @default(now())
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorUser   User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, module, createdAt(sort: Desc)])
  @@index([companyId, action, createdAt(sort: Desc)])
  @@index([actorUserId])
  @@index([entityType, entityId])
}

model CompanyLocation {
  id                      String                  @id @default(cuid())
  companyId               String
  shadowParentLocationId  String?
  name                    String
  address                 String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  invoiceEmail            String?
  invoiceFooter           String?
  invoiceHeader           String?
  invoicePhone            String?
  invoiceSubHeader        String?
  shopifyLocationId       String?
  shopifyShopName         String?
  shortName               String?
  locationReference       String?
  defaultMerchantUserId   String?
  logoUrl                 String?
  shopifyAdminStoreHandle String?
  manualInvoicePrefix     String?
  manualInvoiceNextSeq    Int                     @default(0)
  manualInvoiceSeqPadding Int                     @default(3)
  erpnextCompany          String?
  erpnextWarehouse        String?
  erpnextInstanceId       String?
  fulfillmentBlocked      Boolean                 @default(false)
  isMainCompany           Boolean                 @default(false)
  company                 Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  erpnextInstance         ErpnextInstance?        @relation(fields: [erpnextInstanceId], references: [id], onDelete: SetNull)
  defaultMerchant         User?                   @relation("LocationDefaultMerchant", fields: [defaultMerchantUserId], references: [id])
  shadowParentLocation    CompanyLocation?        @relation("LocationShadowParent", fields: [shadowParentLocationId], references: [id], onDelete: SetNull)
  shadowLocations         CompanyLocation[]       @relation("LocationShadowParent")
  profiles                EmployeeProfile[]
  failedOrderWebhooks     FailedOrderWebhook[]
  invites                 Invite[]
  orders                  Order[]
  productItems            ProductItem[]
  riderCashHandoverItems  RiderCashHandoverItem[]
  stickerBatchItems       StickerBatchItem[]
  smsNotificationConfigs  SmsNotificationConfig[]
  shippingChargeOptions   ShippingChargeOption[]

  @@index([shopifyLocationId])
  @@index([companyId, shadowParentLocationId])
}

model ShippingChargeOption {
  id                String          @id @default(cuid())
  companyId         String
  companyLocationId String
  label             String
  amount            Decimal         @db.Decimal(12, 2)
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyLocation   CompanyLocation @relation(fields: [companyLocationId], references: [id], onDelete: Cascade)

  @@unique([companyLocationId, label])
  @@index([companyId, companyLocationId])
}

model Customer {
  id                String    @id @default(cuid())
  companyId         String
  shopifyCustomerId String
  email             String?
  firstName         String?
  lastName          String?
  phone             String?
  defaultAddress    Json?
  lastPurchaseAt    DateTime?
  orderCount        Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders            Order[]

  @@unique([companyId, shopifyCustomerId])
}

model Order {
  id                           String                 @id @default(cuid())
  companyId                    String
  companyLocationId            String
  assignedMerchantId           String?
  customerId                   String?
  shopifyOrderId               String                 @unique
  sourceName                   String
  shopifyUserId                String?
  orderNumber                  String?
  name                         String?
  totalPrice                   Decimal                @db.Decimal(12, 2)
  subtotalPrice                Decimal?               @db.Decimal(12, 2)
  totalDiscounts               Decimal?               @db.Decimal(12, 2)
  totalTax                     Decimal?               @db.Decimal(12, 2)
  totalShipping                Decimal?               @db.Decimal(12, 2)
  currency                     String?
  financialStatus              String?
  fulfillmentStatus            String?
  /// Shopify `payment_gateway_names` (deduped, trimmed). Empty when unknown.
  paymentGatewayNames          String[]               @default([])
  /// First gateway in `paymentGatewayNames` — used for aggregates (one amount per order).
  paymentGatewayPrimary        String?
  deliveryOutcome              DeliveryOutcome?
  deliveryFailedReason         String?
  customerEmail                String?
  customerPhone                String?
  shippingAddress              Json?
  billingAddress               Json?
  discountCodes                Json?
  discountApplications         Json?
  shippingLines                Json?
  rawPayload                   Json?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  deliveryCompleteAt           DateTime?
  dispatchedAt                 DateTime?
  dispatchedByCourierServiceId String?
  dispatchedByRiderId          String?
  dispatchedToCustomer         Boolean                @default(false)
  fulfillmentStage             FulfillmentStage       @default(order_received)
  fulfillmentStageEnteredAt    DateTime?
  invoiceCompleteAt            DateTime?
  packageHoldReasonId          String?
  packageOnHoldAt              DateTime?
  packageReadyAt               DateTime?
  printCount                   Int                    @default(0)
  riderDeliveryToken           String?                @unique
  sampleFreeIssueCompleteAt    DateTime?
  sampleFreeIssueCompleteById  String?
  sampleFreeIssueSendLaterDate DateTime?
  deliveryCompleteById         String?
  dispatchedById               String?
  invoiceCompleteById          String?
  lastPrintedAt                DateTime?
  lastRiderUpdateAt            DateTime?
  lastPrintedById              String?
  packageReadyById             String?
  assignedMerchant             User?                  @relation("OrderAssignedMerchant", fields: [assignedMerchantId], references: [id])
  company                      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyLocation              CompanyLocation        @relation(fields: [companyLocationId], references: [id], onDelete: Cascade)
  customer                     Customer?              @relation(fields: [customerId], references: [id])
  deliveryPayment              DeliveryPayment?
  deliveryCompleteBy           User?                  @relation("OrderDeliveryCompleteBy", fields: [deliveryCompleteById], references: [id])
  dispatchedByCourierService   CourierService?        @relation(fields: [dispatchedByCourierServiceId], references: [id])
  dispatchedBy                 User?                  @relation("OrderDispatchedBy", fields: [dispatchedById], references: [id])
  dispatchedByRider            User?                  @relation("OrderDispatchedByRider", fields: [dispatchedByRiderId], references: [id])
  invoiceCompleteBy            User?                  @relation("OrderInvoiceCompleteBy", fields: [invoiceCompleteById], references: [id])
  lastPrintedBy                User?                  @relation("OrderLastPrintedBy", fields: [lastPrintedById], references: [id])
  packageHoldReason            PackageHoldReason?     @relation(fields: [packageHoldReasonId], references: [id])
  packageReadyBy               User?                  @relation("OrderPackageReadyBy", fields: [packageReadyById], references: [id])
  sampleFreeIssueCompleteBy    User?                  @relation("OrderSampleFreeIssueCompleteBy", fields: [sampleFreeIssueCompleteById], references: [id])
  lineItems                    OrderLineItem[]
  exchangesAsOriginal          OrderExchange[]        @relation("OrderExchangeOriginalOrder")
  exchangesAsReplacement       OrderExchange[]        @relation("OrderExchangeReplacementOrder")
  remarks                      OrderRemark[]
  riderDeliveryTask            RiderDeliveryTask?
  merchantReview               MerchantOrderReview?
  returns                      OrderReturn[]
  approvalRequests             ApprovalRequest[]
  sampleFreeIssues             OrderSampleFreeIssue[]
  waybills                     OrderWaybill[]
  pickListGroupOrders          PickListGroupOrder[]

  erpnextInvoiceId             String?
  erpnextSyncError             String?
  erpnextSyncFailedAt          DateTime?
  erpnextSyncAutoRetryCount    Int                    @default(0)
  erpnextSyncLastAutoRetryAt   DateTime?
  erpnextSyncNextAutoRetryAt   DateTime?
  erpnextSyncRetryLeaseExpiresAt DateTime?

  erpPeSyncError                 String?
  erpPeSyncFailedAt              DateTime?
  erpPeSyncMop                   String?

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, fulfillmentStage, createdAt(sort: Desc)])
  @@index([companyId, fulfillmentStage, sampleFreeIssueSendLaterDate])
  @@index([companyId, companyLocationId, createdAt(sort: Desc)])
  @@index([companyId, assignedMerchantId, createdAt(sort: Desc)])
  @@index([companyId, customerEmail, createdAt(sort: Desc)])
  @@index([companyId, customerPhone, createdAt(sort: Desc)])
  @@index([erpnextInvoiceId])
  @@index([companyId, erpnextSyncNextAutoRetryAt])
}

model PickListGroup {
  id           String    @id @default(cuid())
  companyId    String
  printedById  String
  createdAt    DateTime  @default(now())
  downloadedAt DateTime?

  company   Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  printedBy User                 @relation("PickListGroupPrintedBy", fields: [printedById], references: [id])
  orders    PickListGroupOrder[]

  @@index([companyId, downloadedAt, createdAt(sort: Desc)])
}

model PickListGroupOrder {
  id              String @id @default(cuid())
  pickListGroupId String
  orderId         String

  pickListGroup PickListGroup @relation(fields: [pickListGroupId], references: [id], onDelete: Cascade)
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([pickListGroupId, orderId])
  @@index([orderId])
}

model OrderWaybill {
  id            String         @id @default(cuid())
  companyId     String
  orderId       String?
  uploadId      String?
  invoiceNumber String
  waybillNo     String
  courierName   String?
  source        String         @default("manual")
  rawPayload    Json?
  uploadedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order         Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  upload        WaybillUpload? @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  @@unique([companyId, waybillNo])
  @@index([companyId, invoiceNumber])
  @@index([companyId, uploadId])
  @@index([companyId, orderId, createdAt(sort: Desc)])
  @@index([companyId, createdAt(sort: Desc)])
}

model WaybillUpload {
  id            String         @id @default(cuid())
  companyId     String
  uploadedById  String?
  fileName      String
  fileType      String
  totalRows     Int            @default(0)
  importedRows  Int            @default(0)
  invalidRows   Int            @default(0)
  unmatchedRows Int            @default(0)
  status        String         @default("completed")
  summary       Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy    User?          @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  waybills      OrderWaybill[]

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, uploadedById, createdAt(sort: Desc)])
}

model MerchantOrderReview {
  id               String    @id @default(cuid())
  companyId        String
  orderId          String    @unique
  merchantUserId   String?
  reviewStatus     String    @default("pending")
  customerRating   Int?
  customerFeedback String?
  itemFeedback     String?
  merchantNotes    String?
  followUpNeeded   Boolean   @default(false)
  reviewMarkedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  merchantUser     User?     @relation("MerchantOrderReviewUser", fields: [merchantUserId], references: [id], onDelete: SetNull)
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([companyId, reviewStatus, updatedAt(sort: Desc)])
  @@index([companyId, merchantUserId, reviewStatus, updatedAt(sort: Desc)])
}

model OrderReturn {
  id                  String                  @id @default(cuid())
  companyId           String
  orderId             String
  merchantUserId      String?
  dispatchedAt        DateTime
  returnDate          DateTime
  shippingServiceType String
  shippingServiceName String
  riderId             String?
  courierServiceId    String?
  actionStatus        OrderReturnActionStatus @default(pending)
  actionType          String?
  actionRemark        String?
  returnRemark        String?
  remarkTemplate      String?
  cancelRemark        String?
  cancelRequestedAt   DateTime?
  actionDate          DateTime?
  returnedById        String?
  actionById          String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  company             Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order               Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  merchantUser        User?                   @relation("OrderReturnMerchantUser", fields: [merchantUserId], references: [id], onDelete: SetNull)
  returnedBy          User?                   @relation("OrderReturnReturnedBy", fields: [returnedById], references: [id], onDelete: SetNull)
  actionBy            User?                   @relation("OrderReturnActionBy", fields: [actionById], references: [id], onDelete: SetNull)
  rider               User?                   @relation("OrderReturnRider", fields: [riderId], references: [id], onDelete: SetNull)
  courierService      CourierService?         @relation(fields: [courierServiceId], references: [id], onDelete: SetNull)
