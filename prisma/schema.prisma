enum FulfillmentStage {
  order_received
  sample_free_issue
  print
  returned_to_store
  returned
  ready_to_dispatch
  dispatched
  invoice_complete
  delivery_complete
}

enum RiderDeliveryTaskStatus {
  assigned
  accepted
  arrived
  completed
  failed
}

enum RiderDeliveryKind {
  normal
  rearranged
  exchange
}

enum OldItemCollectionStatus {
  pending
  collected
  not_collected
}

enum DeliveryPaymentMethod {
  cod
  bank_transfer
  card
  already_paid
}

enum DeliveryCollectionStatus {
  pending
  collected
  partially_collected
  not_collected
}

enum DeliveryOutcome {
  pending
  delivered
  failed
}

enum OrderReturnActionStatus {
  pending
  solved
}

enum OrderExchangeReason {
  damaged_item
  wrong_item
  other
}

enum OrderExchangeStatus {
  pending
  solved
}

enum RiderCashHandoverStatus {
  submitted
  received
}

enum RiderMobileSessionStatus {
  active
  revoked
}

enum SampleFreeIssueType {
  sample
  free_issue
}

enum CosmoAcademyMediaType {
  voice
  video
  image
  post
}

enum OrderRemarkType {
  internal
  external
}

enum SmsNotificationTrigger {
  order_received
  package_ready
  dispatched
  rider_dispatched
  delivery_complete
}

enum EmployeeStatus {
  active
  resigned
}

model ContactMaster {
  id              String         @id @default(cuid())
  companyId       String
  phoneNumber     String?
  email           String?
  name            String
  lastPurchaseAt  DateTime?
  recentMerchant  String?
  assignedMerchant String?
  source          String?
  country         String?
  zone            String?
  area            String?
  exWebCustomer   Boolean?
  exOffCustomer   Boolean?
  // CRM profile fields
  remarks         String?
  gender          String?
  workPlace       String?
  occupation      String?
  address         String?
  birthYear       Int?
  birthMonth      Int?
  birthDay        Int?
  // Segmentation fields
  serviceProvider String?
  district        String?
  town            String?
  origin          String?
  customerType    String?
  category        String?
  // Contact preferences
  contactSaved    Boolean?
  whatsappAllowed Boolean?
  // Reminder
  remindAt        DateTime?
  remindTime      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  emails          ContactEmail[]
  phones          ContactPhone[]
  // Call center performance tracking: records each allocation update event for this contact
  allocationUpdates ContactAllocationUpdate[]

  @@index([companyId, lastPurchaseAt])
  @@index([companyId, updatedAt(sort: Desc)])
  @@index([companyId, email])
  @@index([companyId, phoneNumber])
  @@index([companyId, assignedMerchant])
  @@index([companyId, source])
  @@index([companyId, country])
  @@index([companyId, zone])
  @@index([companyId, area])
}

model ContactEmail {
  id        String        @id @default(cuid())
  contactId String
  email     String
  isPrimary Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  contact   ContactMaster @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, email])
  @@index([email])
  @@index([contactId])
}

model ContactPhone {
  id          String        @id @default(cuid())
  contactId   String
  phoneNumber String
  isPrimary   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  contact     ContactMaster @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, phoneNumber])
  @@index([phoneNumber])
  @@index([contactId])
}

model Complaint {
  id           String    @id @default(cuid())
  companyId    String
  createdById  String
  title        String
  description  String
  status       String    @default("open")
  resolvedById String?
  resolvedAt   DateTime?
  resolution   String?
