  updatedAt    DateTime  @updatedAt
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User      @relation("ComplaintCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  resolvedBy   User?     @relation("ComplaintResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([companyId, status, createdAt(sort: Desc)])
  @@index([companyId, createdById, createdAt(sort: Desc)])
}

model ContactAllocationOption {
  id        String   @id @default(cuid())
  companyId String
  type      String
