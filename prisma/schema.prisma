  rider            User                     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([cashHandoverId])
  @@index([riderId, collectedAt(sort: Desc)])
  @@index([paymentMethod, collectionStatus])
}

model RiderCashHandover {
