  @@index([exchangeId])
}

model DeliveryPayment {
  id               String                   @id @default(cuid())
  orderId          String                   @unique
  riderId          String
  cashHandoverId   String?
  expectedAmount   Decimal                  @db.Decimal(12, 2)
  collectedAmount  Decimal                  @db.Decimal(12, 2)
