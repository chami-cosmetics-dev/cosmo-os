model ProductItemAsset {
  id           String   @id @default(cuid())
  companyId    String
  sku          String
  type         String
  fileName     String
  blobUrl      String
  fileSize     Int?
  mimeType     String?
  provider     String   @default("vercel_blob")
  uploadedById String
  createdAt    DateTime @default(now())

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@index([companyId, sku])
}

// ContactAllocationUpdate: records each time a merchant clicks the Update button
// in the customer allocation panel. Used for the Call Center Performance Analysis
// chart on the dashboard — shows per-merchant update counts broken down by the
// contact's category value (e.g. "Interested", "Not Responding", "Busy").
model ContactAllocationUpdate {
  id           String        @id @default(cuid())
  companyId    String
  contactId    String
  merchantId   String?
  /// Denormalized merchant name so chart data is preserved even if the user account is later deleted
  merchantName String?
  /// The contact's effective category at the time of update (new value if changed in this update, otherwise the existing value)
  category     String?
  createdAt    DateTime      @default(now())

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact  ContactMaster @relation(fields: [contactId], references: [id], onDelete: Cascade)
  merchant User?         @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, merchantId, createdAt(sort: Desc)])
  @@index([companyId, category, createdAt(sort: Desc)])
}

