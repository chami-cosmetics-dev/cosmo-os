{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/failed-webhooks-auto-retry",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/failed-erp-syncs-auto-retry",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/erp-credit-note-reconcile",
      "schedule": "*/15 * * * *"
    }
  ],
  "ignoreCommand": "node scripts/vercel-should-build.mjs",
  "git": {
    "deploymentEnabled": {
      "dev": false,
      "feature/mobile-rider-phase-1": false
    }
  }
}