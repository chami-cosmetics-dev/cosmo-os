{
  "mcpServers": {
    "erpnext": {
      "command": "node",
      "args": ["scripts/mcp-erpnext.mjs"],
      "envFile": ".env"
    },
    "vercel": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.vercel.com"
      ],
      "type": "http",
      "url": "https://mcp.vercel.com"
    }
  }
}
