# Vault OS — local / migration target
# Copy to .env.vault and fill in real values (gitignored)

APP_BASE_URL="https://localhost:3000"
NEXT_PUBLIC_APP_NAME="Vault OS"
NEXT_PUBLIC_APP_INITIALS="VO"

# Neon — Vault OS database
DATABASE_URL="postgresql://neondb_owner:<password>@your-vault-project-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:<password>@your-vault-project.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Auth0 — Vault OS tenant (separate from Cosmo)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_DATABASE_CONNECTION=Username-Password-Authentication

# Maileroo
MAILEROO_API_KEY=
MAILEROO_FROM_EMAIL=noreply@yourdomain.com

# Shopify (Vault store webhooks)
SHOPIFY_WEBHOOK_SECRET=

# Ignore Shopify orders created before this date (YYYY-MM-DD) — no Vault OS import or ERP sync
ORDER_IMPORT_CUTOFF=2026-06-01

# Cloudinary (Vault media)
CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ERPNext (Vault instance — optional)
ERPNEXT_BASE_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_BANK_TRANSFER_MOP=Wire Transfer
ERPNEXT_CASH_MOP=Cash
ERPNEXT_COD_MOP=Cash On Delivery
ERPNEXT_CARD_DELIVERY_MOP=Credit Card
ERPNEXT_TAXES_AND_CHARGES=
ERPNEXT_SHIPPING_RULE=
ERPNEXT_INCOMING_WEBHOOK_SECRET=

# Optional
DB_REQUEST_SLOW_MS=400
PRISMA_LOG_SLOW_QUERIES=false
PRISMA_SLOW_QUERY_MS=250
PRISMA_SLOW_QUERY_SAMPLE_RATE=1
ENABLE_PERF_LOGS=false
